---
import Default from '@astrojs/starlight/components/Head.astro';
import ImageZoom from './ImageZoom.astro';
import CookieConsent from './CookieConsent.astro';

const { entry } = Astro.locals.starlightRoute;
const ogImage = (entry.data as { ogImage?: string })?.ogImage;

// Auto-convert .png/.jpg/.jpeg references to .webp (CI generates WebP versions)
const normalizeToWebp = (path: string) => path.replace(/\.(png|jpe?g)$/i, '.webp');
const ogImagePath = ogImage ? normalizeToWebp(ogImage) : '/og/index.webp';
const ogImageUrl = new URL(ogImagePath, Astro.site).href;

const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---

<Default {...Astro.props}>
  <slot />
</Default>

<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:image" content={ogImageUrl} />

<!-- RSS feed auto-discovery -->
<link rel="alternate" type="application/rss+xml" title="koborin.ai" href="/rss.xml" />
<link rel="alternate" type="application/rss+xml" title="koborin.ai (日本語)" href="/ja/rss.xml" />

{gaMeasurementId && (
  <>
    <!-- GA4 script loader - only loads if user has accepted cookies -->
    <script is:inline define:vars={{ gaMeasurementId }}>
      (function() {
        const STORAGE_KEY = 'cookie_consent';
        const CONSENT_ACCEPTED = 'accepted';

        function hasAcceptedCookies() {
          try {
            return localStorage.getItem(STORAGE_KEY) === CONSENT_ACCEPTED;
          } catch {
            return false;
          }
        }

        function loadGA4() {
          // Prevent double loading
          if (window.ga4Loaded) return;
          window.ga4Loaded = true;

          // Load gtag.js script
          const script = document.createElement('script');
          script.async = true;
          script.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaMeasurementId;
          document.head.appendChild(script);

          // Initialize gtag
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          window.gtag = gtag;
          gtag('js', new Date());
          gtag('config', gaMeasurementId);
        }

        // Check consent on page load
        if (hasAcceptedCookies()) {
          loadGA4();
        }

        // Listen for consent changes (from CookieConsent component)
        window.addEventListener('cookie-consent-changed', function(e) {
          if (e.detail && e.detail.consent === CONSENT_ACCEPTED) {
            loadGA4();
          }
        });

        // Re-check on Astro page transitions
        document.addEventListener('astro:page-load', function() {
          if (hasAcceptedCookies() && !window.ga4Loaded) {
            loadGA4();
          }
        });
      })();
    </script>
  </>
)}

<ImageZoom />
<CookieConsent />
